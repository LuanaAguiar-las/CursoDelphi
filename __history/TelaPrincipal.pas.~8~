unit TelaPrincipal;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls;

type
  TfrmTelaPrincipal = class(TForm)
    lblNota1: TLabel;
    edtNota1: TEdit;
    lblNota2: TLabel;
    edtNota2: TEdit;
    lblNota3: TLabel;
    edtNota3: TEdit;
    btnCalcularMedia: TButton;
    lblMedia: TLabel;
    lblSituacao: TLabel;
    procedure edtNota1Exit(Sender: TObject);
    procedure edtNota2Exit(Sender: TObject);
    procedure edtNota3Exit(Sender: TObject);
    procedure btnCalcularMediaClick(Sender: TObject);
  private
    { Private declarations }
    var nota1, nota2, nota3, media: double;
  public
    { Public declarations }
  end;

var
  frmTelaPrincipal: TfrmTelaPrincipal;

implementation

{$R *.dfm}

procedure TfrmTelaPrincipal.btnCalcularMediaClick(Sender: TObject);
begin
  media := (nota1 + nota2 + nota3)/3;

  if media >= 7 then
  begin
    lblMedia.Caption := ('A mÈdia do aluno È ' + FloatToStr(media) + '.');
    lblSituacao.Caption := ('Aprovado!!!');
  end

  else if (media >= 5) and (media < 7) then
  begin
    lblMedia.Caption := ('A mÈdia do aluno È ' + FloatToStr(media) + '.');
    lblSituacao.Caption := ('RecuperaÁ„o!!!');
  end

  else
  begin
    lblMedia.Caption := ('A mÈdia do aluno È ' + FloatToStr(media) + '.');
    lblSituacao.Caption := ('Reprovado!!!');
  end;


end;

procedure TfrmTelaPrincipal.edtNota1Exit(Sender: TObject);
begin
  if (not TryStrToFloat(edtNota1.Text, nota1)) or (nota1 < 0) or (nota1 > 10) then
  begin
    ShowMessage('Digite uma nota v·lida entre 0 e 10');
    edtnota1.Clear;
    edtnota1.SetFocus;
  end;
end;

procedure TfrmTelaPrincipal.edtNota2Exit(Sender: TObject);
begin
  if (not TryStrToFloat(edtNota2.Text, nota2)) or (nota2 < 0) or (nota2 > 10) then
  begin
    ShowMessage('Digite uma nota v·lida entre 0 e 10');
    edtnota2.Clear;
    edtnota2.SetFocus;
  end;
end;

procedure TfrmTelaPrincipal.edtNota3Exit(Sender: TObject);
begin
  if (not TryStrToFloat(edtNota3.Text, nota3)) or (nota3 < 0) or (nota3 > 10) then
  begin
    ShowMessage('Digite uma nota v·lida entre 0 e 10');
    edtnota3.Clear;
    edtnota3.SetFocus;
  end;
end;

end.
